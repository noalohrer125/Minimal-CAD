{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "site": "minimalcad-dev",
      "public": "dist/Minimal-CAD/browser",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/uploadStlToServer",
          "run": {
            "serviceId": "minimalcad-stl-step-api-dev",
            "region": "europe-west6"
          }
        },
        {
          "source": "/convert",
          "run": {
            "serviceId": "minimalcad-stl-step-api-dev",
            "region": "europe-west6"
          }
        },
        {
          "source": "/download",
          "run": {
            "serviceId": "minimalcad-stl-step-api-dev",
            "region": "europe-west6"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "site": "mincad-dev",
      "public": "dist/Minimal-CAD/browser",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/uploadStlToServer",
          "run": {
            "serviceId": "minimalcad-stl-step-api-dev",
            "region": "europe-west6"
          }
        },
        {
          "source": "/convert",
          "run": {
            "serviceId": "minimalcad-stl-step-api-dev",
            "region": "europe-west6"
          }
        },
        {
          "source": "/download",
          "run": {
            "serviceId": "minimalcad-stl-step-api-dev",
            "region": "europe-west6"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
