{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "min-cad",
    "public": "dist/Minimal-CAD/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/uploadStlToServer",
        "run": {
          "serviceId": "minimalcad-stl-step-api-prod",
          "region": "europe-west6"
        }
      },
      {
        "source": "/convert",
        "run": {
          "serviceId": "minimalcad-stl-step-api-prod",
          "region": "europe-west6"
        }
      },
      {
        "source": "/download",
        "run": {
          "serviceId": "minimalcad-stl-step-api-prod",
          "region": "europe-west6"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
